// ─── Objection quick-access menu ───────────────────────────────────────────
const objections = [
  { label: 'What\'s your commission?', next: 'commission_question' },
  { label: 'Not ready to sell yet', next: 'not_ready' },
  { label: 'Already have an agent', next: 'have_agent' },
  { label: 'Just trying to sell insurance?', next: 'insurance_pushback' },
  { label: 'Already have life insurance', next: 'have_insurance' },
];

let history = [];
let currentNode = 'start';

function getPhaseClass(phase) {
  const map = { opening: 'phase-opening', bridge: 'phase-bridge', close: 'phase-close', objection: 'phase-objection', insurance: 'phase-insurance', end: 'phase-end' };
  return map[phase] || '';
}
function getTagClass(phase) {
  const map = { opening: 'tag-opening', bridge: 'tag-bridge', close: 'tag-close', objection: 'tag-objection', insurance: 'tag-insurance', end: 'tag-end' };
  return map[phase] || '';
}

function updatePhaseIndicator(index) {
  const dots = document.querySelectorAll('.phase-dot');
  dots.forEach((d, i) => {
    d.classList.remove('active', 'done');
    if (i < index) d.classList.add('done');
    else if (i === index) d.classList.add('active');
  });
}

function renderBreadcrumb() {
  const bc = document.getElementById('breadcrumb');
  bc.innerHTML = history.map((h, i) => {
    const cls = h.type === 'yes' ? 'yes-crumb' : h.type === 'no' ? 'no-crumb' : '';
    return `<div class="crumb ${cls}">${h.label}</div>`;
  }).join('');
}

function navigate(nodeId, choiceLabel, choiceType) {
  if (choiceLabel) {
    history.push({ label: choiceLabel, type: choiceType });
  }
  currentNode = nodeId;
  renderNode(nodeId);
  renderBreadcrumb();
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

function reset() {
  history = [];
  currentNode = 'start';
  renderNode('start');
  renderBreadcrumb();
  updatePhaseIndicator(0);
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

function renderNode(nodeId) {
  const node = nodes[nodeId];
  if (!node) return;
  updatePhaseIndicator(node.phase_index || 0);

  const container = document.getElementById('nodeContainer');

  if (node.isEnd) {
    container.innerHTML = `
      <div class="node-card ${getPhaseClass(node.phase)} end-card">
        <div class="end-icon">${node.endIcon}</div>
        <div class="end-title">${node.endTitle}</div>
        <div class="end-desc">${node.endDesc}</div>
        ${node.script ? `
        <div class="script-box" style="max-width:480px;margin:0 auto 24px;">
          <div class="script-label">Say This</div>
          <div class="script-text">${node.script}</div>
        </div>` : ''}
        <div class="next-step-list">
          <h4>Next Steps</h4>
          ${node.nextSteps.map(s => `<li>${s}</li>`).join('')}
        </div>
      </div>
      ${renderObjectionMenu()}
    `;
    return;
  }

  const choicesHtml = (node.choices || []).map(c => {
    const btnClass = c.type === 'yes' ? 'yes-btn' : c.type === 'no' ? 'no-btn' : 'neutral-btn';
    const iconClass = c.type === 'yes' ? 'yes-icon' : c.type === 'no' ? 'no-icon' : 'neutral-icon';
    const iconText = c.type === 'yes' ? '✓' : c.type === 'no' ? '✕' : '→';
    return `
      <button class="choice-btn ${btnClass}" onclick="navigate('${c.next}', '${c.label.replace(/'/g,"\\'")}', '${c.type}')">
        <div class="choice-icon ${iconClass}">${iconText}</div>
        <div class="choice-content">
          <div class="choice-label">${c.label}</div>
          <div class="choice-desc">${c.desc}</div>
        </div>
      </button>
    `;
  }).join('');

  container.innerHTML = `
    <div class="node-card ${getPhaseClass(node.phase)}">
      <div class="phase-tag ${getTagClass(node.phase)}">${node.phaseTag}</div>
      <div class="node-title">${node.title}</div>
      <div class="node-subtitle">${node.subtitle}</div>
      <div class="script-box">
        <div class="script-label">Say This</div>
        <div class="script-text">${node.script}</div>
      </div>
      <div class="question-label">${node.question}</div>
      <div class="choices">${choicesHtml}</div>
      ${node.tip ? `<div class="tip-box"><div class="tip-icon">💡</div><div class="tip-text"><strong>Pro tip:</strong> ${node.tip}</div></div>` : ''}
    </div>
    ${renderObjectionMenu()}
  `;
}

function renderObjectionMenu() {
  const items = objections.map(o => `
    <button class="choice-btn neutral-btn" style="padding:11px 16px;" onclick="navigate('${o.next}', 'Objection: ${o.label.replace(/'/g,"\\'")}', 'neutral')">
      <div class="choice-icon neutral-icon" style="width:22px;height:22px;font-size:11px;">!</div>
      <div class="choice-content">
        <div class="choice-label" style="font-size:12px;">${o.label}</div>
      </div>
    </button>
  `).join('');

  return `
    <div class="node-card" style="border-color:#2a2d3a44;">
      <div class="phase-tag tag-objection">⚡ Quick Objections</div>
      <div class="node-subtitle" style="margin-bottom:14px;">If they raise an objection at any point, tap it here</div>
      <div class="choices" style="display:grid;grid-template-columns:1fr 1fr;gap:8px;">${items}</div>
    </div>
  `;
}

// Init
renderNode('start');
</script>

